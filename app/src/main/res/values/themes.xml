<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Splash Screen Theme -->
    <style name="Theme.Hesap.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background_light</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">300</item>
        <item name="postSplashScreenTheme">@style/Theme.Hesap</item>
    </style>

    <!-- Base application theme -->
    <style name="Base.Theme.Hesap" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/splash_background_light</item>
        <item name="android:statusBarColor">@color/splash_background_light</item>
        <item name="android:navigationBarColor">@color/splash_background_light</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Hesap" parent="Base.Theme.Hesap" />
</resources>